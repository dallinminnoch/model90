    "**/edge-debug-profile/**": true,
    "**/edge-headless-profile/**": true,
    "**/edge-data/**": true,
    "**/edge-crash/**": true
  },
  "search.exclude": {
    "**/edge-cdp-profile/**": true,
    "**/edge-cdp-profile2/**": true,
    "**/edge-debug-profile/**": true,
    "**/edge-headless-profile/**": true,
    "**/edge-data/**": true,
    "**/edge-crash/**": true
  }
}
