{
  "liveServer.settings.ignoreFiles": [
    "**/.vscode/**",
    "**/.git/**",
    "**/edge-cdp-profile/**",
    "**/edge-cdp-profile2/**",
    "**/edge-debug-profile/**",
    "**/edge-headless-profile/**",
    "**/edge-data/**",
    "**/edge-crash/**",
    "**/cdp-log.txt",
    "**/nav-debug.png",
    "**/nav-debug-after.png"
  ],
  "files.watcherExclude": {
